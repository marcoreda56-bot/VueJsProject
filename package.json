    "primevue": "^4.5.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.3.0",
    "json-server": "^1.0.0-beta.13",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
